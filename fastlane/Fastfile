default_platform(:ios)

platform :ios do

  desc "Run unit tests"
  lane :test do
    xcodebuild(
      project: "nano-SYNAPSYS/nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
      build_for_testing: true,
      test_without_building: false
    )
  end

  desc "Build the app"
  lane :build do
    build_app(
      project: "nano-SYNAPSYS/nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      configuration: "Release",
      sdk: "iphoneos",
      export_method: "app-store",
      skip_package_ipa: true,
      destination: "generic/platform=iOS"
    )
  end

  desc "Archive and upload to TestFlight"
  lane :beta do |options|
    # Set up code signing with match
    match(
      type: "appstore",
      app_identifier: "com.aievolve.nanosynapsys",
      force_for_new_devices: true,
      readonly: true
    )

    # Build the app
    build_app(
      project: "nano-SYNAPSYS/nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      configuration: "Release",
      sdk: "iphoneos",
      export_method: "app-store",
      export_options: {
        method: "app-store",
        signingStyle: "automatic",
        stripSwiftSymbols: true,
        teamID: ENV["TEAM_ID"]
      },
      output_directory: "build",
      output_name: "nano-SYNAPSYS.ipa",
      destination: "generic/platform=iOS"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key_path: ENV["ASC_KEY_FILEPATH"] || "#{Dir.home}/.appstore/AuthKey_#{options[:asc_key_id]}.p8",
      ipa: "build/nano-SYNAPSYS.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )

    slack(
      message: "Successfully uploaded build to TestFlight",
      success: true
    ) if ENV["SLACK_URL"]
  end

  desc "Submit for App Store review"
  lane :release do |options|
    # Upload to TestFlight first
    beta(options)

    # Submit latest build for review
    submit_for_review(
      app_identifier: "com.aievolve.nanosynapsys",
      skip_waiting_for_initial_submission: true
    )

    slack(
      message: "Build submitted for App Store review",
      success: true
    ) if ENV["SLACK_URL"]
  end

  desc "Build and run UI tests"
  lane :ui_tests do
    scan(
      project: "nano-SYNAPSYS/nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      devices: ["iPhone 15"],
      configuration: "Debug",
      clean: true,
      build_for_testing: true,
      only_testing: "nano_SYNAPSYSUITests"
    )
  end

end
