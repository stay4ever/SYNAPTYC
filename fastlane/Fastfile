default_platform(:ios)

platform :ios do
  desc "Run unit tests"
  lane :test do
    run_tests(
      project: "nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      device: "iPhone 15",
      clean: true
    )
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    # Skip git status check in CI (generated files like Gemfile.lock and asc_api_key.json make it dirty)
    unless ENV["CI"]
      ensure_git_status_clean
    end

    # Increment build number using current timestamp for uniqueness
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "nano-SYNAPSYS.xcodeproj"
    )

    # Build the app (automatic signing with -allowProvisioningUpdates)
    build_app(
      project: "nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      export_method: "app-store",
      skip_profile_detection: true,
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"]
      },
      xcargs: "DEVELOPMENT_TEAM='#{ENV["TEAM_ID"]}' -allowProvisioningUpdates -authenticationKeyPath '#{ENV["APP_STORE_CONNECT_API_KEY_PATH"]}' -authenticationKeyID '#{ENV["ASC_KEY_ID"]}' -authenticationKeyIssuerID '#{ENV["ASC_ISSUER_ID"]}'",
      output_directory: "./build",
      output_name: "nano-SYNAPSYS.ipa",
      clean: true
    )

    # Upload to TestFlight
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      apple_id: ENV["APP_STORE_CONNECT_APP_ID"],
      api_key_path: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )

    # Tag the release
    version = get_version_number(xcodeproj: "nano-SYNAPSYS.xcodeproj")
    build = get_build_number(xcodeproj: "nano-SYNAPSYS.xcodeproj")
    add_git_tag(tag: "v#{version}-#{build}")
  end

  desc "Build only (no upload) — for CI validation"
  lane :build do
    build_app(
      project: "nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "nano-SYNAPSYS.ipa",
      clean: true
    )
  end

  desc "Bump version number"
  lane :bump_version do |options|
    bump_type = options[:type] || "patch"
    increment_version_number(
      bump_type: bump_type,
      xcodeproj: "nano-SYNAPSYS.xcodeproj"
    )
  end
end
