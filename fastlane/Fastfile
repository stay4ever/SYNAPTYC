default_platform(:ios)

platform :ios do

  desc "Run unit tests"
  lane :test do
    xcodebuild(
      project: "SYNAPTYC.xcodeproj",
      scheme: "SYNAPTYC",
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
      build_for_testing: true,
      test_without_building: false
    )
  end

  desc "Archive and upload to TestFlight"
  lane :beta do
    # Auto-increment build number using timestamp
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "SYNAPTYC.xcodeproj"
    )

    # Set up ASC API key BEFORE build so Xcode can auto-provision
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"],
      duration: 1200,
      in_house: false
    )

    # Build and archive using the certificate + profile installed by the workflow steps
    build_app(
      project: "SYNAPTYC.xcodeproj",
      scheme: "SYNAPTYC",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "manual",
        stripSwiftSymbols: true,
        teamID: "LF9DXU9P25",
        provisioningProfiles: {
          "com.aievolution.nanosynapsys" => ENV["PP_NAME"]
        }
      },
      output_directory: "build",
      output_name: "SYNAPTYC.ipa",
      destination: "generic/platform=iOS",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER='#{ENV['PP_NAME']}' DEVELOPMENT_TEAM=LF9DXU9P25"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/SYNAPTYC.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )

    # Tag the release
    version = get_version_number(xcodeproj: "SYNAPTYC.xcodeproj")
    build = get_build_number(xcodeproj: "SYNAPTYC.xcodeproj")
    add_git_tag(tag: "v#{version}-#{build}")
  end

  desc "Build and run UI tests"
  lane :ui_tests do
    scan(
      project: "SYNAPTYC.xcodeproj",
      scheme: "SYNAPTYC",
      devices: ["iPhone 15"],
      configuration: "Debug",
      clean: true,
      build_for_testing: true,
      only_testing: "SYNAPTYCUITests"
    )
  end

end
