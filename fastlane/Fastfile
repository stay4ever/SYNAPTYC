default_platform(:ios)

platform :ios do

  desc "Run unit tests"
  lane :test do
    xcodebuild(
      project: "nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      configuration: "Debug",
      sdk: "iphonesimulator",
      destination: "generic/platform=iOS Simulator",
      build_for_testing: true,
      test_without_building: false
    )
  end

  desc "Archive and upload to TestFlight"
  lane :beta do
    # Auto-increment build number using timestamp
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj: "nano-SYNAPSYS.xcodeproj"
    )

    # Build the app with automatic signing
    build_app(
      project: "nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      configuration: "Release",
      export_method: "app-store",
      export_options: {
        signingStyle: "automatic",
        stripSwiftSymbols: true,
        teamID: ENV["TEAM_ID"]
      },
      output_directory: "build",
      output_name: "nano-SYNAPSYS.ipa",
      destination: "generic/platform=iOS",
      xcargs: "DEVELOPMENT_TEAM='#{ENV["TEAM_ID"]}' CODE_SIGN_STYLE=Manual CODE_SIGN_IDENTITY='Apple Distribution' PROVISIONING_PROFILE_SPECIFIER='#{ENV["PP_NAME"]}' -allowProvisioningUpdates -authenticationKeyPath '#{ENV["ASC_KEY_PATH"]}' -authenticationKeyID '#{ENV["ASC_KEY_ID"]}' -authenticationKeyIssuerID '#{ENV["ASC_ISSUER_ID"]}'"
    )

    # Set up API key for upload
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/nano-SYNAPSYS.ipa",
      skip_waiting_for_build_processing: true,
      skip_submission: true
    )

    # Tag the release
    version = get_version_number(xcodeproj: "nano-SYNAPSYS.xcodeproj")
    build = get_build_number(xcodeproj: "nano-SYNAPSYS.xcodeproj")
    add_git_tag(tag: "v#{version}-#{build}")
  end

  desc "Build and run UI tests"
  lane :ui_tests do
    scan(
      project: "nano-SYNAPSYS.xcodeproj",
      scheme: "nano-SYNAPSYS",
      devices: ["iPhone 15"],
      configuration: "Debug",
      clean: true,
      build_for_testing: true,
      only_testing: "nano_SYNAPSYSUITests"
    )
  end

end
